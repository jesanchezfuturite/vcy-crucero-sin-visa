---
const experiences = [
  {
    title: "Relajarte en playas cristalinas y paisajes en Antigua.",
    image: "/images/antigua-barbuda.webp",
    reverse: true
  },
  {
    title: "Descubrir el encanto caribeño de Martinica.",
    image: "/images/fort-de-france.webp",
    reverse: false
  },
  {
    title: "Caminar entre cascadas mágicas en Guadalupe.",
    image: "/images/point-a-pitre.webp",
    reverse: true
  },
  {
    title: "Explorar fortalezas coloniales frente al mar en St. Kitts",
    image: "/images/basaterre.webp",
    reverse: false
  },
  {
    title: "Conocer la ciudad y descansar en Santo Domingo.",
    image: "/images/republica-dominicana.webp",
    reverse: true
  }
];
---
<section class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-20 text-gray-900">
      NO SE TRATA SOLO DE CONOCER EL CARIBE, SE TRATA DE:
    </h2>

    <div class="space-y-24">
      {experiences.map((exp, index) => (
        <div class={`flex flex-col ${exp.reverse ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-center gap-12 lg:gap-24`}>
          <div class="w-full lg:w-1/2">
            <div class="relative group">
              <div class="absolute -inset-4 bg-acero-profundo/10 rounded-3xl transform rotate-2 group-hover:rotate-0 transition-transform duration-500"></div>
              <img 
                src={exp.image} 
                alt={exp.title} 
                class="relative rounded-2xl shadow-2xl w-full h-[400px] object-cover transform -rotate-2 group-hover:rotate-0 transition-transform duration-500"
              />
            </div>
          </div>
          <div class="w-full lg:w-1/2 text-center lg:text-left">
            <span class="text-6xl font-bold text-acero-profundo/10 mb-4 block">{index + 1}</span>
            <h3 class="text-2xl md:text-4xl font-semibold text-gray-800 leading-snug">
              {exp.title}
            </h3>
            <div class="mt-8 h-1 w-20 bg-acero-profundo mx-auto lg:mx-0"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
