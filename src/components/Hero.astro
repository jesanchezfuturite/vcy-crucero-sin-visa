---
---
<section class="relative min-h-[80vh] flex items-center justify-center bg-acero-profundo text-white overflow-hidden">
  <!-- Fondo con gradiente para emular fondo náutico oscuro -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-acero-profundo/90 z-0"></div>
  
  <div class="container mx-auto px-6 relative z-10 text-center">
    <span class="inline-block px-4 py-1 bg-white/10 backdrop-blur-md border border-white/20 rounded-full text-sm font-semibold tracking-wider mb-6 animate-fade-in">
      CRUCERO POR EL CARIBE 2027
    </span>
    
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 max-w-5xl mx-auto">
      VIAJA POR EL CARIBE SIN VISA A BORDO DE UN <span class="text-white/80">RESORT DE LUJO</span>
    </h1>
    
    <div class="flex flex-col md:flex-row items-center justify-center gap-4 mb-8 text-lg md:text-xl font-light">
      <span>10 días / 9 noches</span>
      <span class="hidden md:inline">•</span>
      <span>Salida: 22 de febrero de 2027</span>
    </div>
    
    <div class="bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-2xl max-w-md mx-auto mb-10">
      <p class="text-2xl md:text-3xl font-bold mb-2">$48,700 MXN</p>
      <p class="text-sm text-white/70 mb-4">(Por persona en habitación doble)</p>
      <p class="text-lg font-semibold text-white">Aparta hoy con solo $5,500 MXN</p>
    </div>
    
    <div class="flex flex-col items-center gap-4">
      <a href="#formulario-contacto" class="bg-white text-acero-profundo hover:bg-gray-100 px-10 py-4 rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-xl">
        Quiero vivir el Caribe desde un crucero
      </a>
      <p class="text-sm text-white/60">Cupo limitado · Atención antes y durante el viaje</p>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>
