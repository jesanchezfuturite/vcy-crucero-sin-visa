---
const stops = [
  {
    city: "Santo Domingo",
    image: "/images/republica-dominicana.webp",
    desc: "Vuelo desde CDMX, traslados y hotel incluidos. El punto perfecto para iniciar y terminar el viaje explorando su zona colonial."
  },
  {
    city: "Isla de Antigua",
    image: "/images/antigua-barbuda.webp",
    desc: "Tu primera parada en el paraíso. Famosa por sus playas de arena blanca impecable y aguas turquesas ultra cristalinas."
  },
  {
    city: "Fort-de-France",
    image: "/images/fort-de-france.webp",
    desc: "Una escala con encanto único. Disfruta de un ambiente completamente francés, tiendas chic y exuberante vegetación tropical."
  },
  {
    city: "Pointe-à-Pitre",
    image: "/images/point-a-pitre.webp",
    desc: "Naturaleza y sabor en estado puro. Explora cascadas mágicas en la selva, destilerías de ron tradicional y deliciosa cocina criolla."
  },
  {
    city: "Basseterre",
    image: "/images/basaterre.webp",
    desc: "Vistas de postal e historia. Descubre imponentes fortalezas coloniales del siglo XVII construidas en lo alto de verdes colinas."
  },
  {
    city: "Road Town",
    image: "/images/antigua-barbuda.webp", // Reutilizando para Road Town si no hay específica
    desc: "El paraíso del mar. Una isla espectacular ideal para nadar y hacer esnórquel en arrecifes de coral llenos de vida marina."
  }
];
---
<section class="py-24 bg-acero-profundo text-white overflow-hidden">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16">
      TU ITINERARIO EN UNA SOLA MIRADA
    </h2>

    <div class="relative group/slider">
      <!-- Botón Anterior -->
      <button id="itinerary-prev" class="absolute left-2 md:-left-4 top-[225px] -translate-y-1/2 z-20 bg-white text-acero-profundo p-3 rounded-full shadow-lg hover:bg-gray-100 transition-all hidden md:flex items-center justify-center opacity-0 group-hover/slider:opacity-100" aria-label="Anterior">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>

      <!-- Botón Siguiente -->
      <button id="itinerary-next" class="absolute right-2 md:-right-4 top-[225px] -translate-y-1/2 z-20 bg-white text-acero-profundo p-3 rounded-full shadow-lg hover:bg-gray-100 transition-all hidden md:flex items-center justify-center opacity-0 group-hover/slider:opacity-100" aria-label="Siguiente">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>

      <div id="itinerary-scroll" class="flex overflow-x-auto gap-6 pb-12 snap-x scrollbar-hide">
        {stops.map((stop, index) => (
          <div class="min-w-[85vw] md:min-w-[400px] snap-center relative overflow-hidden bg-acero-profundo border border-white/20 p-8 rounded-3xl flex flex-col justify-between h-[450px] group">
            <!-- Background Image -->
            <div class="absolute inset-0 z-0">
              <img src={stop.image} alt={stop.city} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            </div>

            <div class="relative z-10">
              <span class="text-5xl font-bold text-white/20 mb-4 block">Día {index + 1}</span>
              <h3 class="text-2xl font-bold mb-4">{stop.city}</h3>
              <p class="text-white/80 leading-relaxed text-lg">
                {stop.desc}
              </p>
            </div>
            <div class="relative z-10 mt-6 flex items-center gap-2 text-white/70 font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>Parada Destacada</span>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Controles visuales interactivos -->
      <div class="flex justify-center gap-2 mt-4">
        {stops.map((_, i) => (
          <button class="slider-dot w-2 h-2 rounded-full transition-colors duration-300 bg-white/30 hover:bg-white/60" aria-label={`Ir a la parada ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function setupItinerarySlider() {
    const scrollContainer = document.getElementById('itinerary-scroll');
    const dots = document.querySelectorAll('.slider-dot');
    const prevBtn = document.getElementById('itinerary-prev');
    const nextBtn = document.getElementById('itinerary-next');
    
    if (!scrollContainer) return;

    const getActiveIndex = () => {
      const scrollPosition = scrollContainer.scrollLeft;
      const containerOffset = scrollContainer.offsetLeft;
      const containerCenter = scrollPosition + (scrollContainer.clientWidth / 2);
      
      let activeIndex = 0;
      let minDistance = Infinity;

      const items = scrollContainer.children;
      for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const itemCenter = (item.offsetLeft - containerOffset) + (item.clientWidth / 2);
        const distance = Math.abs(containerCenter - itemCenter);
        
        if (distance < minDistance) {
          minDistance = distance;
          activeIndex = i;
        }
      }
      return activeIndex;
    };

    const scrollToItem = (index) => {
      const items = scrollContainer.children;
      if (items[index]) {
        const item = items[index];
        const containerOffset = scrollContainer.offsetLeft;
        const itemCenter = (item.offsetLeft - containerOffset) + (item.clientWidth / 2);
        const scrollTarget = itemCenter - (scrollContainer.clientWidth / 2);
        
        scrollContainer.scrollTo({
          left: scrollTarget,
          behavior: 'smooth'
        });
      }
    };

    const updateDots = () => {
      const activeIndex = getActiveIndex();
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.add('bg-white');
          dot.classList.remove('bg-white/30');
        } else {
          dot.classList.remove('bg-white');
          dot.classList.add('bg-white/30');
        }
      });

      if (prevBtn) prevBtn.style.opacity = activeIndex === 0 ? '0.5' : '';
      if (nextBtn) nextBtn.style.opacity = activeIndex === scrollContainer.children.length - 1 ? '0.5' : '';
      if (prevBtn) prevBtn.style.pointerEvents = activeIndex === 0 ? 'none' : 'auto';
      if (nextBtn) nextBtn.style.pointerEvents = activeIndex === scrollContainer.children.length - 1 ? 'none' : 'auto';
    };

    // Escuchar el evento de scroll
    scrollContainer.addEventListener('scroll', updateDots, { passive: true });
    
    // Inicializar el estado de los puntos
    updateDots();

    // Permitir clic en los puntos para navegar
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => scrollToItem(index));
    });

    // Botones previo y siguiente
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        scrollToItem(Math.max(0, getActiveIndex() - 1));
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        scrollToItem(Math.min(scrollContainer.children.length - 1, getActiveIndex() + 1));
      });
    }
  }

  // Inicializar al cargar
  setupItinerarySlider();
  // Soporte para Astro View Transitions si están activadas
  document.addEventListener('astro:page-load', setupItinerarySlider);
</script>
