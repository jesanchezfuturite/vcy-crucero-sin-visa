---
const supports = [
  {
    title: "Asistencia personalizada",
    desc: "Acompañamiento y soporte de la agencia en los puntos clave de la ruta."
  },
  {
    title: "Seguro de viaje internacional AC 35",
    desc: "Con cobertura médica y de asistencia incluida para tu total tranquilidad durante todo el trayecto."
  },
  {
    title: "Traslados completamente privados",
    desc: "Organizados y esperándote en cada aeropuerto, hotel y puerto para evitar imprevistos."
  },
  {
    title: "Agencia con trayectoria",
    desc: "Para respaldar cada paso de tu reservación, pagos y entrega puntual de documentación de viaje."
  }
];
---
<section class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 text-gray-900">
      EL RESPALDO QUE NECESITAS AL VIAJAR LEJOS
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {supports.map(item => (
        <div class="p-8 bg-gray-50 rounded-3xl border border-gray-100 flex flex-col items-center text-center">
          <div class="w-14 h-14 bg-maritimo-azul/10 text-maritimo-azul rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-800 leading-tight">{item.title}</h3>
          <p class="text-gray-600">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
