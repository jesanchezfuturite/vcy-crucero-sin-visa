---
<section class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 text-gray-900">
      EL RESPALDO QUE NECESITAS AL VIAJAR LEJOS
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {supports.map(item => (
        <div class="p-8 bg-gray-50 rounded-3xl border border-gray-100 flex flex-col items-center text-center">
          <div class={`h-14 bg-maritimo-azul/10 text-maritimo-azul rounded-full flex items-center justify-center mb-6 ${item.iconClass}`} set:html={item.icon}>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-800 leading-tight">{item.title}</h3>
          <p class="text-gray-600">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
